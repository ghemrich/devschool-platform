# === DATABASE (Required) ===
DB_USER=openschool
DB_PASSWORD=openschool
DB_NAME=openschool
DATABASE_URL=postgresql://openschool:openschool@db:5432/openschool

# === SECURITY (Required — change in production!) ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# === APPLICATION ===
BASE_URL=http://localhost
# Options: development, staging, production
# Controls: log level, Swagger UI visibility
ENVIRONMENT=development
# Comma-separated origins for CORS
ALLOWED_ORIGINS=http://localhost,http://localhost:4321

# === GITHUB OAUTH (Required for login) ===
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub organization for repo lookups (optional)
GITHUB_ORG=
# Personal Access Token (classic) from an org owner with admin:org scope.
# Enables auto-inviting users to the GitHub org on first login.
# Create at: https://github.com/settings/tokens → "Generate new token (classic)" → check "admin:org"
GITHUB_ORG_ADMIN_TOKEN=
# Webhook signature verification (optional, recommended)
# Generate with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=
# Skip webhook signature verification (dev only, never in production!)
# WEBHOOK_SKIP_VERIFY=false

# === DISCORD (Optional — for notifications and bot) ===
# Platform notifications webhook (enrollment, certificates → Discord channel)
# Create at: Discord → Channel settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
# Bot token from: https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=
# Server (guild) ID — right-click server name with Developer Mode enabled
DISCORD_GUILD_ID=
# Role mapping: "student:ROLE_ID,mentor:ROLE_ID,admin:ROLE_ID"
DISCORD_ROLE_MAP=
